{
  "name": "academic-journal-tracker",
  "version": "0.2.0",
  "description": "NestJS monorepo: polls academic journal sources on a BullMQ schedule and dispatches notifications",
  "private": true,
  "scripts": {
    "build": "bunx nest build && bunx nest build api",
    "build:worker": "bunx nest build",
    "build:api": "bunx nest build api",
    "start:worker": "bunx nest start",
    "start:worker:dev": "bunx nest start --watch",
    "start:api": "bunx nest start api",
    "start:api:dev": "bunx nest start api --watch",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "test": "bunx jest",
    "test:watch": "bunx jest --watch",
    "lint": "bunx eslint \"{apps,libs}/**/*.ts\" --fix",
    "migration:generate": "bunx typeorm migration:generate -d libs/database/src/data-source.ts",
    "migration:run": "bunx typeorm migration:run -d libs/database/src/data-source.ts",
    "migration:revert": "bunx typeorm migration:revert -d libs/database/src/data-source.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/typeorm": "^10.0.2",
    "better-sqlite3": "^11.7.0",
    "bullmq": "^5.34.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "fast-xml-parser": "^4.5.1",
    "ioredis": "^5.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "roots": ["<rootDir>/apps", "<rootDir>/libs"],
    "testRegex": ".*\\.(spec|e2e-spec)\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": ["ts-jest", {
        "tsconfig": "<rootDir>/tsconfig.json"
      }]
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@journal/database(|/.*)$": "<rootDir>/libs/database/src$1",
      "^@journal/shared(|/.*)$": "<rootDir>/libs/shared/src$1"
    }
  }
}
