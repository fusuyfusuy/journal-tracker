      { "from": "fetching_journal", "event": "FETCH_OK", "to": "processing_articles", "action": "normalizeArticles", "input": "FetchResult", "output": "NormalizedArticle[]" },
      { "from": "fetching_journal", "event": "FETCH_ERROR", "to": "error_fetch", "action": "handleFetchError", "input": "Error", "output": "void" },
      { "from": "fetching_journal", "event": "TIMEOUT", "to": "error_fetch", "action": "handleTimeout", "input": "void", "output": "void" },
      { "from": "processing_articles.dedupe_article", "event": "NEW_ARTICLE", "to": "processing_articles.persist_article", "action": "persistArticle", "input": "NormalizedArticle", "output": "Article" },
      { "from": "processing_articles.dedupe_article", "event": "DUPLICATE", "to": "processing_articles.dedupe_article", "action": "skipArticle", "input": "NormalizedArticle", "output": "void" },
      { "from": "processing_articles.dedupe_article", "event": "CHECK", "to": "processing_articles.dedupe_article", "action": "dedupeArticle", "input": "NormalizedArticle", "output": "boolean" },
