  "generated_at": "2026-04-14T23:50:00Z",
  "mode": "greenfield",
  "language": "typescript",
  "runtime": "bun",
  "summary": "Bun+TypeScript service that periodically polls academic journal sources (RSS, arXiv, Crossref, PubMed, HTML), deduplicates articles in SQLite (bun:sqlite), and dispatches notifications over email (Resend) and generic HTTP webhook channels.",

  "dependencies": {
    "runtime": {
      "zod": "latest",
      "fast-xml-parser": "latest"
    },
    "dev": {
      "typescript": "latest",
      "@types/bun": "latest"
    },
    "notes": [
      "bun:sqlite is a Bun built-in — no SQLite driver dependency.",
      "Resend is called via raw fetch to the REST API; no @resend/node SDK dependency.",
      "bun test is the Bun built-in test runner; no vitest/jest needed."
    ]
  },

  "entities": [
    {
      "name": "Journal",
      "description": "A polled upstream journal source. Persistent row in SQLite.",
      "fields": [
        { "name": "id", "type": "number", "notes": "INTEGER PRIMARY KEY AUTOINCREMENT" },
        { "name": "name", "type": "string", "notes": "Human-readable name" },
        { "name": "fetcher_type", "type": "enum('rss'|'arxiv'|'crossref'|'pubmed'|'html')" },
        { "name": "feed_url", "type": "string", "notes": "Non-empty URL" },
        { "name": "active", "type": "boolean" },
        { "name": "created_at", "type": "string", "notes": "ISO-8601 UTC" }
      ],
      "constraints": [
        "feed_url MUST be non-empty",
        "fetcher_type MUST be one of the enum values"
      ]
    },
    {
      "name": "Article",
      "description": "A deduplicated article row. Persisted BEFORE any notification is dispatched.",
      "fields": [
        { "name": "id", "type": "number" },
        { "name": "journal_id", "type": "number", "notes": "FK -> journals.id" },
        { "name": "title", "type": "string" },
        { "name": "url", "type": "string" },
        { "name": "doi", "type": "string | null" },
        { "name": "published_at", "type": "string", "notes": "ISO-8601 UTC; falls back to fetch time" },
        { "name": "dedupe_key", "type": "string", "notes": "UNIQUE; DOI if present, else canonical URL" },
        { "name": "created_at", "type": "string" }
      ],
      "constraints": [
        "dedupe_key UNIQUE at SQL layer",
        "published_at is ISO-8601 UTC string"
      ]
    },
    {
      "name": "Subscriber",
      "description": "External notification recipient.",
      "fields": [
        { "name": "id", "type": "number" },
        { "name": "channel_type", "type": "enum('email'|'webhook')" },
        { "name": "destination", "type": "string", "notes": "email addr OR https?:// URL" },
        { "name": "active", "type": "boolean" },
        { "name": "created_at", "type": "string" }
      ],
      "constraints": [
        "destination must syntactically validate per channel_type"
      ]
    },
    {
      "name": "FetchResult",
      "description": "In-memory return value from a Fetcher adapter.",
      "fields": [
        { "name": "journal_id", "type": "number" },
        { "name": "articles", "type": "NormalizedArticle[]" },
        { "name": "fetched_at", "type": "string" },
        { "name": "error", "type": "FetchError | null" }
      ]
    },
    {
      "name": "NormalizedArticle",
      "description": "Pre-persistence article shape returned by a Fetcher.",
      "fields": [
        { "name": "title", "type": "string" },
        { "name": "url", "type": "string" },
        { "name": "doi", "type": "string | null" },
        { "name": "published_at", "type": "string" }
      ]
    },
    {
      "name": "NotificationEvent",
      "description": "In-memory structured log event for a dispatch attempt.",
      "fields": [
        { "name": "article_id", "type": "number" },
        { "name": "subscriber_id", "type": "number" },
        { "name": "channel", "type": "enum('email'|'webhook')" },
        { "name": "status", "type": "enum('ok'|'error')" },
        { "name": "error_message", "type": "string | null" },
        { "name": "timestamp", "type": "string" }
      ]
    },
    {
      "name": "CycleSummary",
      "description": "Per-cycle aggregated log event.",
      "fields": [
        { "name": "started_at", "type": "string" },
        { "name": "finished_at", "type": "string" },
        { "name": "journals_processed", "type": "number" },
        { "name": "articles_new", "type": "number" },
        { "name": "errors", "type": "number" }
      ]
    }
  ],

  "features": [
    {
      "name": "scheduler",
      "description": "Interval-based single-flight loop that ticks every CHECK_INTERVAL_MS (default 6h, min 1h). Skips overrunning ticks. Handles SIGINT/SIGTERM for graceful shutdown.",
      "flows": ["Flow 1", "Flow 3", "Flow 4"]
    },
    {
      "name": "fetching",
      "description": "Pluggable Fetcher interface with implementations for rss (full), arxiv (stub), and reserved placeholders for crossref/pubmed/html. All set descriptive User-Agent.",
      "flows": ["Flow 1"]
    },
    {
      "name": "storage_dedup",
      "description": "SQLite (bun:sqlite) persistence with schema created on startup via CREATE TABLE IF NOT EXISTS. UNIQUE(dedupe_key) enforces idempotency.",
      "flows": ["Flow 1"]
    },
    {
      "name": "notification_dispatch",
      "description": "Pluggable Notifier interface with email (Resend REST) and webhook (generic HTTP POST) implementations. Per-subscriber try/catch with no retry in v1.",
      "flows": ["Flow 2"]
    },
    {
      "name": "cli",
      "description": "Entry point honoring --once flag (one-shot) vs bare invocation (long-running scheduler). Validates env at startup.",
      "flows": ["Flow 3", "Flow 4"]
    },
    {
      "name": "seeding",
      "description": "Out-of-band seed script (or raw SQL) to insert rows into journals/subscribers; changes picked up next cycle without restart.",
      "flows": ["Flow 5"]
    }
  ],

  "flows": [
    {
      "id": "flow-1",
      "name": "Scheduled Check Cycle",
      "trigger": "Scheduler tick OR CLI one-shot",
      "steps": [
        "loadActiveJournals()",
        "for each Journal: resolveFetcher -> fetchJournalArticles -> normalizeArticles",
        "for each NormalizedArticle: dedupeArticle -> persistArticle (if new) -> dispatch Flow 2",
        "logJournalResult per journal",
        "logCycleSummary"
      ]
    },
    {
      "id": "flow-2",
      "name": "Notification Dispatch",
      "trigger": "New article persisted in Flow 1",
      "steps": [
        "loadActiveSubscribers()",
        "for each Subscriber: resolveNotifier -> renderPayload -> dispatchNotification -> logDeliverOk|handleNotifyError"
      ]
    },
    { "id": "flow-3", "name": "One-Shot CLI Run", "trigger": "--once flag", "steps": ["init -> run Flow 1 once -> exit"] },
    { "id": "flow-4", "name": "Long-Running Scheduler Mode", "trigger": "bare invocation", "steps": ["init -> Flow 1 immediately -> interval loop -> SIGINT/SIGTERM graceful exit"] },
    { "id": "flow-5", "name": "Data Seeding", "trigger": "Operator seed script / SQL", "steps": ["insert rows -> next cycle picks them up"] }
  ],

  "statechart": {
    "id": "check_cycle",
    "initial": "idle",
    "context": {
      "journals": "Journal[]",
      "current_journal_index": "number",
      "current_articles": "NormalizedArticle[]",
      "current_article_index": "number",
      "subscribers": "Subscriber[]",
