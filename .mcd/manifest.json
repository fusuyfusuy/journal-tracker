      { "from": "processing_articles.dispatch_for_article.deliver_notification", "event": "DELIVER_ERROR", "to": "processing_articles.dispatch_for_article.error_notify", "action": "handleNotifyError", "input": "Error", "output": "void" },
      { "from": "processing_articles.dispatch_for_article.deliver_notification", "event": "TIMEOUT", "to": "processing_articles.dispatch_for_article.error_notify", "action": "handleTimeout", "input": "void", "output": "void" },
      { "from": "processing_articles.dispatch_for_article.error_notify", "event": "CONTINUE", "to": "processing_articles.dispatch_for_article.pick_subscriber", "action": "logAndContinue", "input": "void", "output": "void" },
      { "from": "processing_articles.error_db_article", "event": "CONTINUE", "to": "processing_articles.dedupe_article", "action": "logAndContinue", "input": "void", "output": "void" },
      { "from": "processing_articles", "event": "ARTICLES_DONE", "to": "next_journal", "action": "logJournalResult", "input": "CycleSummary", "output": "void" },
      { "from": "error_fetch", "event": "CONTINUE", "to": "next_journal", "action": "logAndContinue", "input": "void", "output": "void" },
