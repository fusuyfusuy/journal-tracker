      "summary": "CycleSummary"
    },
    "states": {
      "idle": {
        "on": {
          "CYCLE_TICK": { "target": "loading_journals", "action": "loadActiveJournals" },
          "SHUTDOWN": { "target": "terminated" }
        }
      },
      "loading_journals": {
        "on": {
          "JOURNALS_LOADED": { "target": "fetching_journal", "action": "selectNextJournal" },
          "NO_JOURNALS": { "target": "cycle_complete", "action": "logCycleSummary" },
          "DB_ERROR": { "target": "error_db", "action": "handleDbError" }
        }
      },
      "fetching_journal": {
        "after": { "30000": { "target": "error_fetch", "action": "handleTimeout" } },
        "on": {
          "FETCH_OK": { "target": "processing_articles", "action": "normalizeArticles" },
          "FETCH_ERROR": { "target": "error_fetch", "action": "handleFetchError" }
        }
      },
      "processing_articles": {
        "initial": "dedupe_article",
        "states": {
          "dedupe_article": {
            "on": {
              "NEW_ARTICLE": { "target": "persist_article", "action": "persistArticle" },
              "DUPLICATE": { "target": "dedupe_article", "action": "skipArticle" },
              "ARTICLES_DONE": { "target": "#check_cycle.next_journal", "action": "logJournalResult" }
            }
          },
          "persist_article": {
            "on": {
              "PERSIST_OK": { "target": "dispatch_for_article", "action": "loadSubscribers" },
              "PERSIST_ERROR": { "target": "error_db_article", "action": "handleDbError" }
            }
          },
          "dispatch_for_article": {
            "initial": "pick_subscriber",
            "states": {
              "pick_subscriber": {
                "on": {
                  "HAS_SUBSCRIBER": { "target": "deliver_notification", "action": "dispatchNotification" },
                  "NO_MORE_SUBSCRIBERS": { "target": "#check_cycle.processing_articles.dedupe_article", "action": "nextArticle" }
                }
              },
              "deliver_notification": {
                "after": { "15000": { "target": "error_notify", "action": "handleTimeout" } },
                "on": {
                  "DELIVER_OK": { "target": "pick_subscriber", "action": "logDeliverOk" },
                  "DELIVER_ERROR": { "target": "error_notify", "action": "handleNotifyError" }
                }
              },
              "error_notify": {
                "on": { "CONTINUE": { "target": "pick_subscriber", "action": "logAndContinue" } }
              }
            }
          },
          "error_db_article": {
            "on": { "CONTINUE": { "target": "dedupe_article", "action": "logAndContinue" } }
          }
        }
      },
      "error_fetch": {
        "on": { "CONTINUE": { "target": "next_journal", "action": "logAndContinue" } }
      },
      "error_db": {
        "on": { "ABORT_CYCLE": { "target": "cycle_complete", "action": "logCycleSummary" } }
      },
      "next_journal": {
        "on": {
          "MORE_JOURNALS": { "target": "fetching_journal", "action": "selectNextJournal" },
          "NO_MORE_JOURNALS": { "target": "cycle_complete", "action": "logCycleSummary" }
        }
      },
      "cycle_complete": {
        "on": { "RESET": { "target": "idle", "action": "resetCycleState" } }
      },
      "terminated": { "type": "final" }
    },
    "transitions": [
      { "from": "idle", "event": "CYCLE_TICK", "to": "loading_journals", "action": "loadActiveJournals", "input": "void", "output": "Journal[]" },
      { "from": "loading_journals", "event": "JOURNALS_LOADED", "to": "fetching_journal", "action": "selectNextJournal", "input": "Journal[]", "output": "Journal" },
      { "from": "loading_journals", "event": "NO_JOURNALS", "to": "cycle_complete", "action": "logCycleSummary", "input": "CycleSummary", "output": "void" },
