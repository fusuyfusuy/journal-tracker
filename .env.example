## Database
DB_PATH=./data/journal-tracker.db
DB_SYNCHRONIZE=false

## Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

## Scheduler
# Polling interval in ms. Min 3_600_000 (1h). Default 21_600_000 (6h).
CHECK_INTERVAL_MS=21600000

## Notifiers
RESEND_API_KEY=re_your_key_here
RESEND_FROM=notifications@example.com

## API
API_PORT=3000

## Authentication
# Comma-separated list of API keys. Format: API_KEYS=key1,key2,key3
# All REST requests must include: X-API-Key: <key>
API_KEYS=
